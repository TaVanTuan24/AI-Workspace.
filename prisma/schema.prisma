generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users                          User[]
  ProviderConnection             ProviderConnection[]
  ProviderDiagnosticsBaseline    ProviderDiagnosticsBaseline[]
  ProviderDiagnosticsDriftAlert  ProviderDiagnosticsDriftAlert[]
  InternalApiKey                 InternalApiKey[]
  InternalApiUsageLog            InternalApiUsageLog[]
  UserModelPreference            UserModelPreference[]
  ProviderRateLimitSetting       ProviderRateLimitSetting[]
  ProviderHealthIncident         ProviderHealthIncident[]
  ProviderDiagnosticsRun         ProviderDiagnosticsRun[]
  memberships                    WorkspaceMembership[]
  invites                        WorkspaceInvite[]
  userRoleAuditEvents            UserRoleAuditEvent[]
  inviteDeliveryAttempts         WorkspaceInviteDeliveryAttempt[]
  quota                          WorkspaceQuota?
  quotaEvents                    WorkspaceQuotaEvent[]

  @@map("workspaces")
}

model User {
  id                              String                           @id @default(cuid())
  email                           String                           @unique
  passwordHash                    String?                          @map("password_hash")
  localAuthSecret                 String?                          @map("local_auth_secret")
  displayName                     String?                          @map("display_name")
  role                            String                           @default("owner")
  workspaceId                     String?                          @map("workspace_id")
  workspace                       Workspace?                       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt                       DateTime                         @default(now()) @map("created_at")
  updatedAt                       DateTime                         @updatedAt @map("updated_at")
  providerSessions                ProviderConnection[]
  threads                         ChatThread[]
  messages                        Message[]
  messageAttachments              MessageAttachment[]
  automationJobs                  AutomationJob[]
  auditLogs                       AuditLog[]
  internalApiKeys                 InternalApiKey[]
  internalApiUsageLogs            InternalApiUsageLog[]
  settings                        UserSettings?
  modelPreferences                UserModelPreference[]
  providerRateLimitSettings       ProviderRateLimitSetting[]
  notificationEvents              NotificationEvent[]
  providerHealthIncidents         ProviderHealthIncident[]
  liveSubModelCaches              ProviderLiveSubModelCache[]
  providerDiagnosticsRuns         ProviderDiagnosticsRun[]
  providerDiagnosticsBaselines    ProviderDiagnosticsBaseline[]
  providerDiagnosticsDriftAlerts  ProviderDiagnosticsDriftAlert[]
  roleAuditEventsAsActor          UserRoleAuditEvent[]             @relation("RoleAuditActor")
  roleAuditEventsAsTarget         UserRoleAuditEvent[]             @relation("RoleAuditTarget")
  memberships                     WorkspaceMembership[]
  invitesSent                     WorkspaceInvite[]                @relation("InviteSender")

  @@index([workspaceId])
  @@map("users")
}

model ProviderConnection {
  id                   String     @id @default(cuid())
  workspaceId          String?    @map("workspace_id")
  workspace            Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId               String     @map("user_id")
  user                 User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             String
  status               String     @default("not_connected")
  encryptedSessionRef  String?    @map("encrypted_session_ref")
  encryptedSessionBlob String?    @map("encrypted_session_blob")
  encryptionVersion    Int?       @map("encryption_version")
  browserProfileId     String?    @map("browser_profile_id")
  lastConnectedAt      DateTime?  @map("last_connected_at")
  lastUsedAt           DateTime?  @map("last_used_at")
  lastValidatedAt      DateTime?  @map("last_validated_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  errorCode            String?    @map("error_code")
  errorMessageSafe     String?    @map("error_message_safe")

  @@unique([userId, provider])
  @@index([status])
  @@index([workspaceId])
  @@map("provider_connections")
}

model ProviderDiagnosticsBaseline {
  id           String     @id @default(cuid())
  workspaceId  String?    @map("workspace_id")
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  connectionId String?    @map("connection_id")

  name        String
  sourceRunId String @map("source_run_id")
  status      String
  fingerprint String

  detectedCapabilitiesJson String? @map("detected_capabilities_json")
  missingCapabilitiesJson  String? @map("missing_capabilities_json")
  selectorHintsJson        String? @map("selector_hints_json")
  metadataJson             String? @map("metadata_json")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, provider, isActive])
  @@index([userId, connectionId])
  @@index([workspaceId])
  @@map("provider_diagnostics_baselines")
}

model ProviderDiagnosticsDriftAlert {
  id           String     @id @default(cuid())
  workspaceId  String?    @map("workspace_id")
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  connectionId String?    @map("connection_id")

  baselineId       String? @map("baseline_id")
  diagnosticsRunId String  @map("diagnostics_run_id")
  severity         String
  status           String  @default("open")

  driftScore                      Int     @map("drift_score")
  summary                         String
  addedDetectedCapabilitiesJson   String? @map("added_detected_capabilities_json")
  removedDetectedCapabilitiesJson String? @map("removed_detected_capabilities_json")
  addedMissingCapabilitiesJson    String? @map("added_missing_capabilities_json")
  removedMissingCapabilitiesJson  String? @map("removed_missing_capabilities_json")
  changedSelectorHintsJson        String? @map("changed_selector_hints_json")
  metadataJson                    String? @map("metadata_json")

  notificationEventId      String? @map("notification_event_id")
  providerHealthIncidentId String? @map("provider_health_incident_id")

  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([userId, provider, status])
  @@index([userId, createdAt])
  @@index([userId, baselineId])
  @@index([workspaceId])
  @@map("provider_diagnostics_drift_alerts")
}

model SchedulerRunStatus {
  id   String @id @default(cuid())
  name String @unique

  enabled        Boolean
  lastStartedAt  DateTime? @map("last_started_at")
  lastFinishedAt DateTime? @map("last_finished_at")
  lastStatus     String?   @map("last_status")
  lastError      String?   @map("last_error")

  lastLockAcquired Boolean? @map("last_lock_acquired")
  lastSummary      String?  @map("last_summary")

  runCount     Int @default(0) @map("run_count")
  failureCount Int @default(0) @map("failure_count")
  skippedCount Int @default(0) @map("skipped_count")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("scheduler_run_statuses")
}

model ChatThread {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  // JSON map of { [provider]: conversationUrl } used to continue the same
  // provider-side conversation across turns. Safe metadata: only provider URLs.
  providerConversationsJson String? @map("provider_conversations_json")
  messages  Message[]
  jobs      AutomationJob[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@index([userId, updatedAt])
  @@map("chat_threads")
}

model Message {
  id           String     @id @default(cuid())
  threadId     String     @map("thread_id")
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String?
  role         String
  content      String
  metadataJson String?    @map("metadata_json")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([threadId, createdAt])
  @@index([userId, createdAt])
  @@map("messages")
}

// Prompt attachment (image or document). Stored in the DB so the worker can
// read it across the api/worker process boundary (which do not share a volume).
// Strict size/type limits apply and rows are deleted once consumed by a job.
model MessageAttachment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String   @map("mime_type")
  sizeBytes Int      @map("size_bytes")
  data      Bytes
  status    String   @default("pending") // pending | consumed
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, status, createdAt])
  @@map("message_attachments")
}

model WorkspaceQuota {
  id          String   @id @default(cuid())
  workspaceId String   @unique @map("workspace_id")
  plan        String   @default("local")

  maxMembers              Int? @map("max_members")
  maxInvites              Int? @map("max_invites")
  maxApiKeys              Int? @map("max_api_keys")
  maxProviderConnections  Int? @map("max_provider_connections")
  maxDiagnosticsBaselines Int? @map("max_diagnostics_baselines")
  maxMonthlyApiRequests   Int? @map("max_monthly_api_requests")
  maxMonthlyInviteEmails  Int? @map("max_monthly_invite_emails")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_quotas")
}

model WorkspaceQuotaEvent {
  id                 String   @id @default(cuid())
  workspaceId        String   @map("workspace_id")
  actorUserId        String?  @map("actor_user_id")
  resource           String
  limit              Int?
  used               Int
  attemptedIncrement Int      @default(1) @map("attempted_increment")
  source             String
  createdAt          DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, resource, createdAt])
  @@map("workspace_quota_events")
}

model AutomationJob {
  id               String      @id @default(cuid())
  userId           String      @map("user_id")
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         String
  threadId         String?     @map("thread_id")
  thread           ChatThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  status           String      @default("queued")
  inputJson        String      @map("input_json")
  outputJson       String?     @map("output_json")
  errorCode        String?     @map("error_code")
  errorMessageSafe String?     @map("error_message_safe")
  startedAt        DateTime?   @map("started_at")
  completedAt      DateTime?   @map("completed_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@index([userId, provider, status])
  @@index([threadId])
  @@map("automation_jobs")
}

model AuditLog {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         String?
  action           String
  result           String
  requestId        String?  @map("request_id")
  ipHash           String?  @map("ip_hash")
  metadataSafeJson String?  @map("metadata_safe_json")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

model UserRoleAuditEvent {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  actorUserId  String   @map("actor_user_id")
  targetUserId String?  @map("target_user_id")
  previousRole   String?  @map("previous_role")
  nextRole       String?  @map("next_role")
  previousStatus String?  @map("previous_status")
  nextStatus     String?  @map("next_status")
  inviteId       String?  @map("invite_id")
  action         String
  createdAt    DateTime @default(now()) @map("created_at")

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser  User      @relation("RoleAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser User?     @relation("RoleAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@map("user_role_audit_events")
}

model InternalApiKey {
  id                 String     @id @default(cuid())
  workspaceId        String?    @map("workspace_id")
  workspace          Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId             String     @map("user_id")
  name               String
  keyPrefix          String     @map("key_prefix")
  keyLast4           String     @map("key_last4")
  keyHash            String     @map("key_hash")
  status             String     @default("active")
  createdAt          DateTime   @default(now()) @map("created_at")
  lastUsedAt         DateTime?  @map("last_used_at")
  revokedAt          DateTime?  @map("revoked_at")
  rotatedAt          DateTime?  @map("rotated_at")
  rateLimitPerMinute Int?       @map("rate_limit_per_minute")

  user        User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLogs   InternalApiUsageLog[]
  modelScopes InternalApiKeyModelScope[]

  @@index([userId])
  @@index([keyPrefix])
  @@index([status])
  @@index([workspaceId])
  @@map("internal_api_keys")
}

model InternalApiUsageLog {
  id String @id @default(cuid())

  workspaceId String? @map("workspace_id")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId       String  @map("user_id")
  apiKeyId     String? @map("api_key_id")
  apiKeyPrefix String? @map("api_key_prefix")
  apiKeyLast4  String? @map("api_key_last4")
  apiKeyName   String? @map("api_key_name")

  model    String
  provider String
  source   String?

  endpoint  String
  requestId String  @map("request_id")
  jobId     String? @map("job_id")

  status         String
  errorCode      String? @map("error_code")
  errorType      String? @map("error_type")
  limitType      String? @map("limit_type")
  limitPerMinute Int?    @map("limit_per_minute")

  stream          Boolean
  messageCount    Int     @map("message_count")
  inputCharCount  Int     @map("input_char_count")
  outputCharCount Int?    @map("output_char_count")

  durationMs       Int? @map("duration_ms")
  queuedMs         Int? @map("queued_ms")
  workerDurationMs Int? @map("worker_duration_ms")

  createdAt DateTime @default(now()) @map("created_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey InternalApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([model, createdAt])
  @@index([provider, createdAt])
  @@index([status, createdAt])
  @@index([workspaceId])
  @@map("internal_api_usage_logs")
}

model UserSettings {
  userId                         String    @id @map("user_id")
  autoSelectFirstUsable          Boolean   @default(true) @map("auto_select_first_usable")
  onboardingCompletedAt          DateTime? @map("onboarding_completed_at")
  onboardingSkippedAt            DateTime? @map("onboarding_skipped_at")
  onboardingLastStep             String?   @map("onboarding_last_step")
  notifyProviderSessionIssues    Boolean   @default(true) @map("notify_provider_session_issues")
  notifyNoUsableModels           Boolean   @default(true) @map("notify_no_usable_models")
  notifyProviderLimitSpikes      Boolean   @default(true) @map("notify_provider_limit_spikes")
  providerLimitSpikeThreshold24h Int       @default(10) @map("provider_limit_spike_threshold_24h")
  notifyWorkspaceQuotaWarnings   Boolean   @default(true) @map("notify_workspace_quota_warnings")
  notifyWorkspaceQuotaExceeded   Boolean   @default(true) @map("notify_workspace_quota_exceeded")
  workspaceQuotaWarningThresholdPercent Int @default(90) @map("workspace_quota_warning_threshold_percent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model UserModelPreference {
  id                    String     @id @default(cuid())
  workspaceId           String?    @map("workspace_id")
  workspace             Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId                String     @map("user_id")
  modelId               String     @map("model_id")
  provider              String
  enabled               Boolean    @default(true)
  isDefault             Boolean    @default(false) @map("is_default")
  priority              Int        @default(100)
  selectedSubModelId    String?    @default("current") @map("selected_sub_model_id")
  selectedSubModelLabel String?    @map("selected_sub_model_label")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, modelId])
  @@index([userId, enabled])
  @@index([userId, priority])
  @@index([workspaceId])
  @@map("user_model_preferences")
}

model ProviderRateLimitSetting {
  id                String     @id @default(cuid())
  workspaceId       String?    @map("workspace_id")
  workspace         Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId            String     @map("user_id")
  provider          String
  requestsPerMinute Int?       @map("requests_per_minute")
  enabled           Boolean    @default(true)
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider])
  @@index([workspaceId])
  @@map("provider_rate_limit_settings")
}

model InternalApiKeyModelScope {
  id        String   @id @default(cuid())
  apiKeyId  String   @map("api_key_id")
  modelId   String   @map("model_id")
  provider  String
  createdAt DateTime @default(now()) @map("created_at")

  apiKey InternalApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@unique([apiKeyId, modelId])
  @@index([apiKeyId])
  @@index([modelId])
  @@map("internal_api_key_model_scopes")
}

model NotificationEvent {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  kind         String
  severity     String
  title        String
  message      String
  provider     String?
  modelId      String?   @map("model_id")
  fingerprint  String
  actionLabel  String?   @map("action_label")
  actionHref   String?   @map("action_href")
  metadataJson String?   @map("metadata_json")
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user             User                          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([userId, kind])
  @@map("notification_events")
}

model ProviderLiveSubModelCache {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  provider      String
  subModelsJson String   @map("sub_models_json")
  detectedAt    DateTime @map("detected_at")
  status        String
  errorCode     String?  @map("error_code")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, detectedAt])
  @@map("provider_live_sub_model_cache")
}

model ProviderHealthIncident {
  id           String     @id @default(cuid())
  workspaceId  String?    @map("workspace_id")
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId       String     @map("user_id")
  provider     String
  connectionId String?    @map("connection_id")

  status         String
  previousStatus String? @map("previous_status")
  severity       String  @default("info")
  reason         String?
  fingerprint    String

  startedAt       DateTime  @default(now()) @map("started_at")
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at")
  resolvedAt      DateTime? @map("resolved_at")
  occurrenceCount Int       @default(1) @map("occurrence_count")

  notificationEventId String? @map("notification_event_id")
  metadata            String? // JSON representation

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, startedAt])
  @@index([userId, status])
  @@index([userId, resolvedAt])
  @@index([workspaceId])
  @@map("provider_health_incidents")
}

model ProviderDiagnosticsRun {
  id           String     @id @default(cuid())
  workspaceId  String?    @map("workspace_id")
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId       String     @map("user_id")
  provider     String
  connectionId String?    @map("connection_id")
  incidentId   String?    @map("incident_id")

  status   String
  summary  String?
  reason   String?
  severity String  @default("info")

  detectedCapabilitiesJson String? @map("detected_capabilities_json")
  missingCapabilitiesJson  String? @map("missing_capabilities_json")
  selectorHintsJson        String? @map("selector_hints_json")
  redactionStatsJson       String? @map("redaction_stats_json")
  metadataJson             String? @map("metadata_json")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  durationMs  Int?      @map("duration_ms")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, startedAt])
  @@index([userId, incidentId])
  @@index([userId, status])
  @@index([workspaceId])
  @@map("provider_diagnostics_runs")
}

model WorkspaceMembership {
  id String @id @default(cuid())

  workspaceId String @map("workspace_id")
  userId      String @map("user_id")
  role        String

  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@index([workspaceId, role])
  @@map("workspace_memberships")
}

model WorkspaceInvite {
  id String @id @default(cuid())

  workspaceId String @map("workspace_id")
  email       String
  role        String

  tokenHash  String    @map("token_hash")
  status     String    @default("pending")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  invitedByUserId String @map("invited_by_user_id")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  deliveryAttempts WorkspaceInviteDeliveryAttempt[]

  @@index([workspaceId, status])
  @@index([email])
  @@index([tokenHash])
  @@map("workspace_invites")
}

model WorkspaceInviteDeliveryAttempt {
  id String @id @default(cuid())

  workspaceId String @map("workspace_id")
  inviteId    String @map("invite_id")

  channel                String
  status                 String
  recipientEmailRedacted String? @map("recipient_email_redacted")
  reason                 String?

  createdAt DateTime @default(now()) @map("created_at")

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invite    WorkspaceInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([inviteId])
  @@map("workspace_invite_delivery_attempts")
}
