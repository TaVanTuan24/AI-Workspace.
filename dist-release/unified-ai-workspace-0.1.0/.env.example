# Runtime
NODE_ENV=development
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000

# Ports and public URLs
WEB_PORT=3000
API_PORT=4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Database
DATABASE_URL=file:./dev.db
# Production/PostgreSQL example:
# DATABASE_URL=postgresql://uaiw:change-me@postgres:5432/uaiw?schema=public

# Redis/BullMQ
REDIS_URL=redis://localhost:6379
CHAT_WORKER_CONCURRENCY=1
CHAT_JOB_TIMEOUT_MS=180000

# Provider automation timeouts
PROVIDER_RESPONSE_IDLE_TIMEOUT_MS=15000
PROVIDER_NAVIGATION_TIMEOUT_MS=30000
PROVIDER_SEND_TIMEOUT_MS=30000

# Session vault
# Required before connecting providers. Generate a 32-byte base64 key with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_MASTER_KEY=
SESSION_MASTER_KEY_ID=local-v1

# App/auth
APP_SECRET=
LOCAL_SINGLE_USER_MODE=true

# OpenAI-compatible internal endpoint
# For production, prefer DB-backed API keys. If DB keys are disabled,
# INTERNAL_API_KEY is required and should be a long random value.
INTERNAL_API_KEY=
INTERNAL_API_SAVE_HISTORY=true
OPENAI_COMPAT_NONSTREAM_TIMEOUT_MS=240000
INTERNAL_API_RATE_LIMIT_PER_MINUTE=30
INTERNAL_API_RATE_LIMIT_MAX_PER_MINUTE=300
PROVIDER_RATE_LIMIT_DEFAULT_PER_MINUTE=30
PROVIDER_RATE_LIMIT_MAX_PER_MINUTE=300
PROVIDER_RATE_LIMIT_CHATGPT_PER_MINUTE=20
PROVIDER_RATE_LIMIT_GEMINI_PER_MINUTE=30
PROVIDER_RATE_LIMIT_GROK_PER_MINUTE=10

# DB-backed internal API keys
ENABLE_DB_API_KEYS=false
API_KEY_HASH_SECRET=
API_USAGE_RETENTION_DAYS=30

# Browser automation
BROWSER_HEADLESS=false
BROWSER_CHANNEL=chromium
LOCAL_BROWSER_MODE=true
BROWSER_PROFILE_ROOT=.data/browser-profiles
SESSION_BLOB_ROOT=.data/session-blobs

# Provider health/readiness cache and scheduler
PROVIDER_HEALTH_TTL_SECONDS=300
PROVIDER_HEALTH_TIMEOUT_MS=60000
PROVIDER_HEALTH_SCHEDULER_ENABLED=false
PROVIDER_HEALTH_SCHEDULER_INTERVAL_SECONDS=900
PROVIDER_HEALTH_SCHEDULER_JITTER_SECONDS=60
PROVIDER_HEALTH_SCHEDULER_LOCK_TTL_SECONDS=840
PROVIDER_HEALTH_SCHEDULER_MAX_USERS_PER_RUN=50

# Local smoke reports are safe JSON metadata and are ignored by git.
SMOKE_REPORT_ROOT=var/smoke-reports
