{
  "name": "unified-ai-workspace",
  "private": true,
  "version": "0.2.0",
  "description": "Local-first browser automation workspace for personal AI accounts.",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @uaiw/web --filter @uaiw/api --filter @uaiw/worker dev",
    "dev:web": "corepack pnpm --filter @uaiw/web dev",
    "dev:api": "corepack pnpm --filter @uaiw/api dev",
    "dev:worker": "corepack pnpm --filter @uaiw/worker dev",
    "smoke:provider": "tsx --tsconfig tools/provider-smoke/tsconfig.json tools/provider-smoke/src/index.ts",
    "smoke:gemini": "pnpm smoke:provider --provider gemini",
    "smoke:gemini:diagnose": "pnpm smoke:provider --provider gemini --mode diagnose-ui --json --report-file ./var/smoke-reports/gemini-diagnose.json",
    "smoke:gemini:validate": "corepack pnpm --silent smoke:provider --provider gemini --mode validate-session --json --report-file ./var/smoke-reports/gemini-validate.json",
    "smoke:gemini:ui": "corepack pnpm --silent smoke:provider --provider gemini --mode detect-ui --json --report-file ./var/smoke-reports/gemini-ui.json",
    "smoke:gemini:full-safe": "corepack pnpm --silent smoke:provider --provider gemini --mode full --no-send --json --report-file ./var/smoke-reports/gemini-full-safe.json",
    "smoke:gemini:send": "corepack pnpm --silent smoke:provider --provider gemini --mode send-message --prompt \"Say hello in one short sentence.\" --yes --json --report-file ./var/smoke-reports/gemini-send.json",
    "smoke:chatgpt": "pnpm smoke:provider --provider chatgpt",
    "smoke:chatgpt:diagnose": "pnpm smoke:provider --provider chatgpt --mode diagnose-ui --json --report-file ./var/smoke-reports/chatgpt-diagnose.json",
    "smoke:chatgpt:validate": "corepack pnpm --silent smoke:provider --provider chatgpt --mode validate-session --json --report-file ./var/smoke-reports/chatgpt-validate.json",
    "smoke:chatgpt:ui": "corepack pnpm --silent smoke:provider --provider chatgpt --mode detect-ui --json --report-file ./var/smoke-reports/chatgpt-ui.json",
    "smoke:chatgpt:full-safe": "corepack pnpm --silent smoke:provider --provider chatgpt --mode full --no-send --json --report-file ./var/smoke-reports/chatgpt-full-safe.json",
    "smoke:chatgpt:send": "corepack pnpm --silent smoke:provider --provider chatgpt --mode send-message --prompt \"Say hello in one short sentence.\" --yes --json --report-file ./var/smoke-reports/chatgpt-send.json",
    "smoke:grok": "pnpm smoke:provider --provider grok",
    "smoke:grok:diagnose": "pnpm smoke:provider --provider grok --mode diagnose-ui --json --report-file ./var/smoke-reports/grok-diagnose.json",
    "smoke:grok:validate": "corepack pnpm --silent smoke:provider --provider grok --mode validate-session --json --report-file ./var/smoke-reports/grok-validate.json",
    "smoke:grok:ui": "corepack pnpm --silent smoke:provider --provider grok --mode detect-ui --json --report-file ./var/smoke-reports/grok-ui.json",
    "smoke:grok:full-safe": "corepack pnpm --silent smoke:provider --provider grok --mode full --no-send --json --report-file ./var/smoke-reports/grok-full-safe.json",
    "smoke:grok:send": "corepack pnpm --silent smoke:provider --provider grok --mode send-message --prompt \"Say hello in one short sentence.\" --yes --json --report-file ./var/smoke-reports/grok-send.json",
    "api-usage:cleanup": "tsx --tsconfig tools/api-usage-cleanup/tsconfig.json tools/api-usage-cleanup/src/index.ts",
    "notification-events:cleanup": "tsx --tsconfig tools/notification-cleanup/tsconfig.json tools/notification-cleanup/src/index.ts",
    "provider-health:run-once": "tsx --tsconfig tools/provider-health-run-once/tsconfig.json tools/provider-health-run-once/src/index.ts",
    "ci:check": "node tools/ci/check.mjs",
    "ci:smoke:ready": "node tools/ci/smoke-ready.mjs",
    "ci:docker:config": "docker compose config",
    "provider-health-incidents:cleanup": "node tools/cleanup/provider-health-incidents.mjs",
    "provider-diagnostics:cleanup": "node tools/cleanup/provider-diagnostics.mjs",
    "provider-diagnostics-drift:cleanup": "node tools/cleanup/provider-diagnostics-drift.mjs",
    "provider-recovery-overrides:expire": "tsx --tsconfig apps/api/tsconfig.json apps/api/src/tools/expireProviderRecoveryOverrides.ts",
    "workspace:invites:expire": "tsx --tsconfig apps/api/tsconfig.json apps/api/src/cli/expire-invites.ts",
    "release:check": "node tools/release/check.mjs",
    "release:notes": "node tools/release/notes.mjs",
    "release:package": "node tools/release/package.mjs",
    "release:sbom": "node tools/release/sbom.mjs",
    "release:verify": "node tools/release/verify.mjs",
    "release:staging:env": "node tools/release/staging-env.mjs",
    "release:staging:verify": "node tools/release/staging-verify.mjs",
    "release:staging:local": "node tools/release/local-staging-smoke.mjs",
    "release:tag:dry-run": "node tools/release/tag-dry-run.mjs",
    "release:sign": "node tools/release/sign.mjs",
    "release:operator:status": "node tools/release/operator-status.mjs",
    "security:audit": "node tools/security/audit.mjs",
    "security:licenses": "node tools/security/licenses.mjs",
    "security:scan": "node tools/security/scan.mjs",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "test:isolation": "node tools/ci/check-test-isolation.mjs",
    "test": "corepack pnpm -r test && node --test tools/release/*.test.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "@types/node": "^20.14.10",
    "prisma": "^5.16.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^6.4.3"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.3"
    }
  },
  "packageManager": "pnpm@9.5.0"
}
