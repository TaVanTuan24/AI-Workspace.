# Local staging template for Unified AI Workspace.
# Copy this file to .env.staging, edit with local-only secrets, and never commit .env.staging.
# Generate strong local secrets. Do not reuse production DBs, Redis, provider sessions, or browser profiles.

# Compose
UAIW_COMPOSE_ENV_FILE=.env.staging
UAIW_API_IMAGE=unified-ai-workspace-api:0.2.0-local-staging
UAIW_WORKER_IMAGE=unified-ai-workspace-worker:0.2.0-local-staging
UAIW_WEB_IMAGE=unified-ai-workspace-web:0.2.0-local-staging

# Runtime
NODE_ENV=production
LOG_LEVEL=info
SHUTDOWN_TIMEOUT_MS=10000

# Ports and public URLs
WEB_PORT=3000
API_PORT=4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Database and Redis
# Local staging defaults use container-local SQLite and the Compose Redis service.
# For Postgres staging, use a staging-only database and enable the postgres profile intentionally.
DATABASE_URL=file:./staging.db
REDIS_URL=redis://redis:6379
CHAT_WORKER_CONCURRENCY=1
CHAT_JOB_TIMEOUT_MS=180000

# App/auth
APP_SECRET=replace-with-local-random-secret
LOCAL_SINGLE_USER_MODE=true

# Session vault and encryption
# Generate 32-byte base64 keys locally:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_MASTER_KEY=replace-with-local-32-byte-base64-key
SESSION_MASTER_KEY_ID=staging-local-v1
API_KEY_HASH_SECRET=replace-with-local-random-secret
NOTIFICATION_SECRET_ENCRYPTION_KEY=replace-with-local-32-byte-base64-key

# OpenAI-compatible internal endpoint
# Keep this local-only. Do not use production API keys.
INTERNAL_API_KEY=replace-with-local-random-internal-api-key
INTERNAL_API_SAVE_HISTORY=false
OPENAI_COMPAT_NONSTREAM_TIMEOUT_MS=240000
INTERNAL_API_RATE_LIMIT_PER_MINUTE=30
INTERNAL_API_RATE_LIMIT_MAX_PER_MINUTE=300
ENABLE_DB_API_KEYS=false

# Provider rate limits
PROVIDER_RATE_LIMIT_DEFAULT_PER_MINUTE=30
PROVIDER_RATE_LIMIT_MAX_PER_MINUTE=300
PROVIDER_RATE_LIMIT_CHATGPT_PER_MINUTE=20
PROVIDER_RATE_LIMIT_GEMINI_PER_MINUTE=30
PROVIDER_RATE_LIMIT_CLAUDE_PER_MINUTE=10

# Browser/provider automation
# Local staging smoke does not run live provider login tests or submit prompts.
BROWSER_HEADLESS=true
BROWSER_CHANNEL=chromium
LOCAL_BROWSER_MODE=true
BROWSER_PROFILE_ROOT=.data/staging-browser-profiles
SESSION_BLOB_ROOT=.data/staging-session-blobs
PROVIDER_RESPONSE_IDLE_TIMEOUT_MS=15000
PROVIDER_NAVIGATION_TIMEOUT_MS=30000
PROVIDER_SEND_TIMEOUT_MS=30000

# Notification delivery and retry
NOTIFICATION_EVENT_RETENTION_DAYS=90
NOTIFICATION_WEBHOOK_TIMEOUT_MS=5000
NOTIFICATION_WEBHOOK_ALLOW_LOCALHOST=false
NOTIFICATION_WEBHOOK_RETRY_ENABLED=true
NOTIFICATION_WEBHOOK_RETRY_MAX_ATTEMPTS=5
NOTIFICATION_WEBHOOK_RETRY_BASE_DELAY_MS=30000
NOTIFICATION_WEBHOOK_RETRY_MAX_DELAY_MS=900000

# Provider health and recovery schedulers
# Keep disabled for release smoke unless intentionally testing scheduler operations.
PROVIDER_HEALTH_TTL_SECONDS=300
PROVIDER_HEALTH_TIMEOUT_MS=60000
PROVIDER_HEALTH_SCHEDULER_ENABLED=false
PROVIDER_HEALTH_SCHEDULER_INTERVAL_SECONDS=900
PROVIDER_HEALTH_SCHEDULER_JITTER_SECONDS=60
PROVIDER_HEALTH_SCHEDULER_LOCK_TTL_SECONDS=840
PROVIDER_HEALTH_SCHEDULER_MAX_USERS_PER_RUN=50
PROVIDER_RECOVERY_OVERRIDE_EXPIRY_SCHEDULER_ENABLED=false
PROVIDER_RECOVERY_OVERRIDE_EXPIRY_INTERVAL_SECONDS=300
PROVIDER_RECOVERY_OVERRIDE_EXPIRY_LOCK_TTL_SECONDS=120
PROVIDER_RECOVERY_OVERRIDE_EXPIRY_MAX_PER_RUN=500

# Cleanup retention
API_USAGE_RETENTION_DAYS=30
PROVIDER_HEALTH_INCIDENT_RETENTION_DAYS=180
PROVIDER_DIAGNOSTICS_RETENTION_DAYS=90
PROVIDER_DIAGNOSTICS_BASELINE_RETENTION_DAYS=365
PROVIDER_DIAGNOSTICS_DRIFT_ALERT_RETENTION_DAYS=180

# Build/release metadata
APP_VERSION=0.2.0
GIT_SHA=local-staging
BUILD_TIME=local-staging
BUILD_SOURCE=local-staging

# Local smoke reports are safe JSON metadata and ignored by git.
SMOKE_REPORT_ROOT=var/smoke-reports
